# SQLite (default, local dev) — file lives in dashboard/backend/prisma/
DATABASE_URL="file:./dev.db"

# To use Postgres instead (PRD §10):
#   1. set provider = "postgresql" in prisma/schema.prisma
#   2. DATABASE_URL="postgresql://user:pass@host:5432/competitor_dashboard"

# API server
PORT=4000

# Path to the Python pipeline, resolved from the repo root.
PIPELINE_SCRIPT="../../tools/competitor_monitor.py"
PYTHON_BIN="python3"

# Where the pipeline writes its JSON run artifacts (relative to repo root)
PIPELINE_OUTPUT_DIR=".tmp"

# Pipeline inference secrets are read from the repo-root .env or process env.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
