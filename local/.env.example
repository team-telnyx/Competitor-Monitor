# Local-only pipeline secrets for development/runtime.
#
# Copy this file to local/.env and fill in real values. local/.env is ignored by git.

# Required for the dashboard Refresh button and LLM classification/digest generation.
OPENAI_API_KEY=

# Optional: override the default model.
OPENAI_MODEL=gpt-4o-mini

# Optional: use an OpenAI-compatible gateway instead of the default OpenAI API.
# OPENAI_BASE_URL=https://api.openai.com/v1
